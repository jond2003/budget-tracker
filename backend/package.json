    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "express": "^5.2.1",
    "install": "^0.13.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "npm": "^11.13.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/express-session": "^1.19.0",
